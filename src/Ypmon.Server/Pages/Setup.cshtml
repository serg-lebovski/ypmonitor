@page
@model SetupModel
@{
    Layout = null;
    ViewData["Title"] = "Первичная настройка";
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Первичная настройка — YPMon</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<div class="auth-wrap">
    <form class="auth-card" method="post">
        <h1>🛡️ YPMon</h1>
        <div class="sub">Создание администратора</div>
        @if (Model.Error is not null)
        {
            <div class="alert-y alert-err">@Model.Error</div>
        }
        <div class="mb-3">
            <label>Логин</label>
            <input class="form-control" asp-for="Username" autofocus />
        </div>
        <div class="mb-3">
            <label>Отображаемое имя</label>
            <input class="form-control" asp-for="DisplayName" />
        </div>
        <div class="mb-3">
            <label>Пароль</label>
            <input class="form-control" type="password" asp-for="Password" />
        </div>
        <div class="mb-3">
            <label>Повтор пароля</label>
            <input class="form-control" type="password" asp-for="PasswordConfirm" />
        </div>
        <button class="btn btn-primary w-100" type="submit">Создать и продолжить</button>
    </form>
</div>
</body>
</html>
