# Скопируйте этот файл в .env и заполните своими значениями.
# .env в git НЕ попадает (содержит пароль БД).

# Порт веб-интерфейса сервера на хосте
YPMON_HTTP_PORT=8080

# Пароль пользователя PostgreSQL (admin_yp). База ypmon и пользователь создаются автоматически
# контейнером postgres при первом запуске.
POSTGRES_PASSWORD=ВАШ_ПАРОЛЬ
