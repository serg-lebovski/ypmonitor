# Скопируйте этот файл в .env и заполните своими значениями.
# .env в git НЕ попадает (содержит пароль).

# Порт веб-интерфейса сервера на хосте
YPMON_HTTP_PORT=8080

# Строка подключения к PostgreSQL
# Пример: Host=10.10.20.25;Port=5432;Database=ypmon;Username=ВАШ_ПОЛЬЗОВАТЕЛЬ;Password=ВАШ_ПАРОЛЬ
YPMON_DB_CONNSTRING=Host=ВАШ_ХОСТ;Port=5432;Database=ypmon;Username=ВАШ_ПОЛЬЗОВАТЕЛЬ;Password=ВАШ_ПАРОЛЬ
