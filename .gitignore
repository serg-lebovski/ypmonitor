# Сборка .NET
bin/
obj/
/dist/
.vs/
*.user

# Данные/рантайм сервера (только в корне — не задевает src/.../Data/)
/data/
*.db
*.db-*

# Рантайм агента (создаётся при работе; может содержать пароли)
config.json
state.json
snapshot.json
runnow.flag
ypmon_update.cmd
agent-updates/

# Секреты окружения (строка подключения с паролем)
.env

# Канал самообновления сервера (создаётся на хосте воркером)
/.update/

# Прочее
*.log

# Собранные бинарники установщиков (не коммитим)
installers/**/Ypmon.Agent.exe
installers/**/Ypmon.Server.exe
installers/**/*.exe
